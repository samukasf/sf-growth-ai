# Supabase (necessário para dados empresariais e histórico remoto do chat)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# OpenAI Responses API
OPENAI_API_KEY=
# Baixa latência/custo por padrão; pode ser trocado por um modelo de maior qualidade.
OPENAI_MODEL=gpt-5.4-mini

# Provedor principal do chat textual: auto | gateway | openai | kimi
# Em "auto", AI_GATEWAY_API_KEY tem precedência; Kimi é usado quando não há gateway
# e KIMI_API_KEY/MOONSHOT_API_KEY está configurada.
SAMUEL_AI_TEXT_PROVIDER=auto

# Kimi K3 / Moonshot AI — chat textual via API compatível com OpenAI Chat Completions
# Não controla a voz Realtime.
KIMI_API_KEY=
# Alias oficial aceito:
MOONSHOT_API_KEY=
KIMI_BASE_URL=https://api.moonshot.ai/v1
KIMI_MODEL=kimi-k3
KIMI_REASONING_EFFORT=max

# Gateway compatível com a Responses API (opcional; tem precedência somente no chat textual)
# Estas variáveis nunca são usadas pela voz Realtime.
AI_GATEWAY_API_KEY=
AI_GATEWAY_BASE_URL=
AI_GATEWAY_MODEL=

# Limite entre 1 e 16000 tokens; padrão: 1800
SAMUEL_AI_MAX_OUTPUT_TOKENS=1800

# OpenAI Realtime API (somente voz WebRTC do Samuel)
# Usa OPENAI_API_KEY no servidor e nunca reutiliza AI_GATEWAY_MODEL.
OPENAI_REALTIME_MODEL=gpt-realtime-2.1

# ---------------------------------------------------------------------------
# Google OAuth (Gmail / Calendar / Drive / Contacts)
# Redirect típico: http://localhost:3000/api/integrations/google/oauth/callback
# ---------------------------------------------------------------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=

# Google Analytics 4
GOOGLE_ANALYTICS_ACCESS_TOKEN=
GOOGLE_ANALYTICS_PROPERTY_ID=
# JSON opcional: { "<companyUuid>": "properties/123456" }
GOOGLE_ANALYTICS_PROPERTY_MAP=

# Google Business Profile
GOOGLE_BUSINESS_ACCESS_TOKEN=
GOOGLE_BUSINESS_LOCATION_NAME=
GOOGLE_BUSINESS_ACCOUNT_NAME=
# JSON opcional: { "<companyUuid>": "locations/..." }
GOOGLE_BUSINESS_LOCATION_MAP=

# Google Search Console
GOOGLE_SEARCH_CONSOLE_ACCESS_TOKEN=
GOOGLE_SEARCH_CONSOLE_SITE_URL=
# JSON opcional: { "<companyUuid>": "https://example.com/" }
GOOGLE_SEARCH_CONSOLE_SITE_MAP=

# Meta (Facebook / Instagram / Ads)
META_ACCESS_TOKEN=
META_PAGE_ID=
META_PAGE_MAP=
META_AD_ACCOUNT_ID=
META_AD_ACCOUNT_MAP=
META_INSTAGRAM_BUSINESS_ID=
META_APP_ID=
META_APP_SECRET=
# Ex.: http://localhost:3000/api/integrations/meta/oauth/callback
META_OAUTH_REDIRECT_URI=

# LinkedIn Company Page (Community Management / Marketing API)
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_ORG_ID=
# JSON opcional: { "<companyUuid>": "123456" }
LINKEDIN_ORG_MAP=

# Market Watcher — NewsAPI (opcional; sem isto usa memórias/intelligence reais)
NEWS_API_KEY=
# Alias aceite:
# MARKET_NEWS_API_KEY=

# Monitor de deploy. Na Vercel, VERCEL_GIT_REPO_OWNER/SLUG são preenchidas automaticamente.
# Use o fallback abaixo apenas fora da Vercel. Token é opcional para repositórios públicos.
GITHUB_REPOSITORY=
GITHUB_TOKEN=

# Agente de código autônomo opcional. Requer uma instalação própria do OpenHands;
# o Samuel Studio permanece funcional sem estas variáveis.
OPENHANDS_BASE_URL=
OPENHANDS_API_KEY=

# Autoevolução Samuel — diagnóstico horário, catálogo multiagente e ponte Ruflo.
# O endpoint público é somente leitura por padrão; use a chave abaixo para futuras
# execuções manuais/worker com ações de escrita.
SAMUEL_AUTONOMY_CRON_SECRET=
AGENT_CATALOG_REPOSITORY_URL=https://github.com/ruvnet/ruflo
RUFLO_REPOSITORY_URL=https://github.com/ruvnet/ruflo
RUFLO_ENABLED=false
# Ex.: npx ruflo@latest mcp start
RUFLO_MCP_COMMAND=
# Configuração declarativa versionada:
# config/samuel-ruflo-swarm.json
