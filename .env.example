# Supabase (já em uso pelo projeto)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase Service Role Key — server-only, NUNCA expor ao browser.
# Necessária apenas para lib/supabase/service-client.ts (tabelas com
# segredos, ex.: google_oauth_connections). Obtenha em
# Project Settings > API > service_role no painel do Supabase.
SUPABASE_SERVICE_ROLE_KEY=

# ---------------------------------------------------------------------------
# Google OAuth & Gmail API (Sprint 86) — integração real, sem mocks.
# Crie um OAuth Client ID (Web application) no Google Cloud Console, habilite
# a Gmail API, Google Calendar API, Google People API e Google Drive API, e
# adicione os scopes gmail.readonly, gmail.compose, gmail.send, calendar,
# contacts.readonly e drive.readonly. Reconecte em /debug/gmail-connect após
# adicionar novos scopes.
# ---------------------------------------------------------------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3000/api/integrations/gmail/callback

# ---------------------------------------------------------------------------
# Samuel Tool Calling — kill-switches por ferramenta (Sprint 80+)
# Defina como "false" para desligar sem deploy.
# ---------------------------------------------------------------------------
# SAMUEL_TOOL_CALLING_ENABLED=false
# SAMUEL_SUPABASE_QUERY_TOOL_ENABLED=false
# SAMUEL_GMAIL_TOOL_ENABLED=false
# SAMUEL_GOOGLE_CALENDAR_TOOL_ENABLED=false
# SAMUEL_GOOGLE_CONTACTS_TOOL_ENABLED=false
# SAMUEL_GOOGLE_DRIVE_TOOL_ENABLED=false
# Ver docs/google-drive-setup.md para ativar Google Drive API e reconectar OAuth.
# SAMUEL_TOOL_INTERPRETER_ENABLED=false
# SAMUEL_MULTI_TOOL_TASK_ORCHESTRATOR_ENABLED=false
# SAMUEL_CONVERSATION_MEMORY_ENABLED=false
# SAMUEL_GOAL_PLANNER_ENABLED=false
# SAMUEL_EXECUTION_MEMORY_ENABLED=false
# SAMUEL_AI_GATEWAY_ENABLED=false
# COMPANY_BRAIN_REAL_DATA_SOURCES_ENABLED=false

# ---------------------------------------------------------------------------
# AI Gateway (core/ai-provider) — todas as chaves são opcionais.
# Um provider sem chave configurada fica isAvailable() = false e o selector
# do Gateway usa fallback automático para outro provider disponível; nenhuma
# funcionalidade existente depende destas variáveis hoje.
# ---------------------------------------------------------------------------

# OpenAI — https://platform.openai.com/api-keys
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Anthropic Claude — https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-haiku-latest

# Google Gemini — https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# DeepSeek — https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat

# Grok / xAI — https://console.x.ai
GROK_API_KEY=
GROK_MODEL=grok-2-latest

# Ollama — servidor local ou auto-hospedado, sem chave. Defina OLLAMA_ENABLED=false
# para desativar explicitamente.
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1
OLLAMA_ENABLED=true
